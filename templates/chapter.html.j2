<!-- Generated by build.py from content.yaml — do not edit by hand -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ chapter.title }} — Learn By Inventing</title>
  <link rel="stylesheet" href="../assets/lbi.css" />
{% if chapter.mathjax %}
  <script>
    window.MathJax = { tex: { inlineMath: [['$','$']] } };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
{% endif %}
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-9TZCPED97E"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-9TZCPED97E');
</script>
</head>
<body>

<nav class="topnav">
  <a href="../index.html">&larr; All chapters</a>
  <span class="topnav-views">
    <strong>Interactive</strong>
    <a href="slides.html">Slides</a>
{% if chapter.colab_url %}
    <a href="{{ chapter.colab_url }}" target="_blank">Notebook (Colab)</a>
{% endif %}
  </span>
</nav>

<h1>{{ chapter.title }}</h1>
{% if chapter.intro %}
<p class="chapter-intro">{{ chapter.intro | md_inline }}</p>
{% endif %}

<div class="global-controls">
  <button id="reveal-all">Reveal all hints &amp; solutions</button>
  <button id="hide-all">Hide all</button>
</div>

{% for block in blocks %}
{% include "blocks/" + block.type + ".html.j2" %}

{% endfor %}
<div class="chapter-footer">
{% if chapter.footer %}
  <p><em>{{ chapter.footer | md_inline }}</em></p>
{% endif %}
  <p>Source on <a href="https://github.com/cloudxlab/learnbyinventing">GitHub</a> &middot; <a href="../index.html">Back to all chapters</a></p>
  <p>&copy; 2026 <a href="https://cloudxlab.com">CloudxLab</a>. All rights reserved.</p>
</div>

<script src="../assets/lbi.js"></script>
</body>
</html>
