<!-- Generated by build.py from content.yaml — do not edit by hand -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ chapter.title }} — Learn By Inventing</title>
  <link rel="stylesheet" href="../assets/lbi.css" />
{% if chapter.mathjax %}
  <script>
    window.MathJax = { tex: { inlineMath: [['$','$']] } };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
{% endif %}
{% include "blocks/ga.html" %}
</head>
<body data-chapter-id="{{ chapter.id }}">

<div class="progress-indicator" id="progress-indicator" data-total="{{ total_parts }}"></div>

<nav class="topnav">
  <a href="../index.html">&larr; All chapters</a>
  <span class="topnav-views">
    <strong>Interactive</strong>
    <a href="slides.html">Slides</a>
    <a href="{{ chapter.id }}.ipynb" download>Notebook</a>
{% if chapter.colab_url %}
    <a href="{{ chapter.colab_url }}" target="_blank">Colab</a>
{% endif %}
  </span>
</nav>

<h1>{{ chapter.title }}</h1>
{% if chapter.intro %}
<p class="chapter-intro">{{ chapter.intro | md_inline }}</p>
{% endif %}

<div class="global-controls">
  <button id="reveal-all">Reveal all hints &amp; solutions</button>
  <button id="hide-all">Hide all</button>
  <button id="reset-all">Reset progress</button>
  <button id="show-completed">Show completed only</button>
</div>

{% for block in blocks %}
{% include "blocks/" + block.type + ".html.j2" %}

{% endfor %}
{% include "footer.html.j2" %}

{% if glossary %}
<button class="glossary-toggle" id="glossary-toggle">Glossary</button>
<div class="glossary-panel" id="glossary-panel">
  <div class="glossary-header">
    <h3>Glossary</h3>
    <button class="glossary-close" id="glossary-close">&times;</button>
  </div>
  <input type="text" class="glossary-search" id="glossary-search" placeholder="Search terms..." />
  <dl class="glossary-list">
{% for g in glossary %}
    <div class="glossary-entry" data-term="{{ g.term | lower }}">
      <dt>{{ g.term }}</dt>
      <dd>{{ g.definition | md_inline }}</dd>
    </div>
{% endfor %}
  </dl>
</div>
{% endif %}

<script src="../assets/lbi.js"></script>
</body>
</html>
