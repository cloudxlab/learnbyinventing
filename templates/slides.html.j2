<!-- Generated by build.py from content.yaml — do not edit by hand -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ chapter.title }} — Slides</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4/dist/reveal.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4/dist/theme/white.css" />
{% if chapter.mathjax %}
  <script>
    window.MathJax = { tex: { inlineMath: [['$','$']] } };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
{% endif %}
  <style>
    .reveal { font-family: Georgia, serif; margin-top: 25px; }
    .reveal .slide-content { font-size: 0.55em; }
    .reveal h1 { font-size: 1.8em; }
    .reveal h2 { font-size: 1.4em; color: #7a6b3a; border-bottom: 2px solid #c8a96e; padding-bottom: 0.3em; }
    .reveal h3 { font-size: 1.1em; }
    .reveal pre { font-size: 0.55em; box-shadow: none; }
    .reveal code { font-family: 'SF Mono', 'Menlo', 'Consolas', monospace; }
    .reveal p code, .reveal li code {
      background: #f0ede6; padding: 0.1em 0.3em; border-radius: 3px;
      color: #c7254e; font-size: 0.85em;
    }
    .reveal pre code { background: #282c34; color: #abb2bf; padding: 0.8em; border-radius: 5px; }
    .reveal table { font-size: 0.7em; margin: 0 auto; }
    .reveal th { background: #f5f3ef; }
    .reveal th, .reveal td { border: 1px solid #ddd; padding: 0.3em 0.6em; }
    .reveal .slide-title { color: #555; font-style: italic; font-size: 0.9em; }
    .reveal ul, .reveal ol { text-align: left; font-size: 0.85em; }
  </style>
</head>
<body>
  <nav class="slides-topnav" style="position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.95);padding:4px 16px;font-size:13px;font-family:sans-serif;border-bottom:1px solid #ddd;display:flex;justify-content:space-between;align-items:center;">
    <a href="../index.html" style="color:#888;text-decoration:none;">&larr; All chapters</a>
    <span style="display:flex;gap:10px;align-items:center;">
      <a href="index.html" style="color:#888;text-decoration:none;">Interactive</a>
      <strong style="color:#333;">Slides</strong>
{% if chapter.colab_url %}
      <a href="{{ chapter.colab_url }}" target="_blank" style="color:#888;text-decoration:none;">Notebook (Colab)</a>
{% endif %}
    </span>
  </nav>
  <div class="reveal">
    <div class="slides">

      <!-- Title slide -->
      <section>
        <h1>{{ chapter.title }}</h1>
{% if chapter.intro %}
        <div class="slide-content slide-title">{{ chapter.intro | md_inline }}</div>
{% endif %}
      </section>

{% for slide in slides %}
{% if slide.part %}
      <!-- Part {{ slide.part.number }}: {{ slide.part.title }} -->
      <section>
        <section>
          <h2>{% if slide.part.number is not none and slide.part.number is number %}Part {{ slide.part.number }}: {% endif %}{{ slide.part.title }}</h2>
{% if slide.part.intro %}
          <div class="slide-content">{{ slide.part.intro | md }}</div>
{% endif %}
        </section>

{% for block in slide.blocks %}
{% if block.type == 'exercise' %}
        <section>
          <h3>{{ block.title }}</h3>
          <div class="slide-content">
{% if block.kind == 'mcq' %}
          {{ block.question | md }}
{% for option in block.options %}
          <p><strong>{{ option.label }}.</strong> {{ option.text }}</p>
{% endfor %}
{% elif block.kind == 'conceptual' %}
{% if block.description is defined and block.description %}
          {{ block.description | md }}
{% endif %}
{% if block.prompts is defined %}
{% for prompt in block.prompts %}
          <p>{{ prompt | md_inline }}</p>
{% endfor %}
{% endif %}
{% else %}
          {{ block.description | md }}
{% endif %}
          </div>
        </section>
{% elif block.type == 'reveal' %}
        <section>
          <div class="slide-content">{{ block.text | md }}</div>
        </section>
{% elif block.type == 'table' %}
        <section>
{% if block.title %}
          <h3>{{ block.title }}</h3>
{% endif %}
          <div class="slide-content">
          <table>
            <tr>
{% for header in block.headers %}
              <th>{{ header | md_inline }}</th>
{% endfor %}
            </tr>
{% for row in block.rows %}
            <tr>
{% for cell in row %}
              <td>{{ cell | md_inline }}</td>
{% endfor %}
            </tr>
{% endfor %}
          </table>
          </div>
        </section>
{% endif %}
{% endfor %}
      </section>
{% endif %}
{% endfor %}

    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/reveal.js@4/dist/reveal.js"></script>
  <script>
    Reveal.initialize({
      hash: true,
      slideNumber: true,
      transition: 'slide',
      width: 1200,
      height: 700,
    });
  </script>
</body>
</html>
