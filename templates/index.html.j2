<!-- Generated by build.py from site.yaml — do not edit by hand -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ header.title }}</title>
  <meta name="description" content="Machine Learning and Computer Science taught through guided discovery — derive every algorithm yourself, step by step.">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Georgia, serif;
      background: #fafaf8;
      color: #1a1a1a;
      max-width: 720px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
      line-height: 1.7;
    }

    /* ── Header ── */
    .site-header {
      border-top: 3px solid #1a1a1a;
      padding-top: 1.5rem;
      margin-bottom: 2.5rem;
    }

    .by-line {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #aaa;
      margin-bottom: 0.6rem;
      font-family: system-ui, sans-serif;
    }

    .by-line a { color: #c8a96e; text-decoration: none; }
    .by-line a:hover { text-decoration: underline; }

    h1 {
      font-size: 2.4rem;
      font-weight: normal;
      letter-spacing: -0.5px;
      margin-bottom: 0.4rem;
    }

    .tagline {
      color: #666;
      font-size: 1.05rem;
      margin-bottom: 1.5rem;
    }

    .philosophy {
      font-size: 1rem;
      color: #333;
      line-height: 1.8;
      margin-bottom: 0.75rem;
    }

    .philosophy-link {
      font-size: 0.88rem;
      color: #c8a96e;
      text-decoration: none;
      font-family: system-ui, sans-serif;
    }
    .philosophy-link:hover { text-decoration: underline; }

    /* ── How to use ── */
    .preface {
      background: #f0ede6;
      border-left: 4px solid #c8a96e;
      padding: 1rem 1.2rem;
      margin: 2rem 0;
      font-size: 0.97rem;
      color: #333;
    }

    .preface strong {
      display: block;
      margin-bottom: 0.4rem;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: #888;
      font-family: system-ui, sans-serif;
    }

    /* ── Curriculum tracks ── */
    .track {
      margin-top: 2.75rem;
    }

    .track-header {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
      margin-bottom: 0.25rem;
    }

    .track-number {
      font-size: 0.68rem;
      font-family: monospace;
      color: #bbb;
    }

    .track-title {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #888;
      font-weight: normal;
      font-family: system-ui, sans-serif;
    }

    .track-desc {
      font-size: 0.88rem;
      color: #888;
      margin-bottom: 0.75rem;
      font-family: system-ui, sans-serif;
      padding-left: 2.8rem;
    }

    ol {
      list-style: none;
      counter-reset: chapter;
      padding: 0;
    }

    ol li {
      counter-increment: chapter;
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
      padding: 0.65rem 0;
      border-bottom: 1px solid #e8e6e0;
      flex-wrap: wrap;
    }

    ol li::before {
      content: counter(chapter, decimal-leading-zero);
      font-size: 0.75rem;
      color: #ccc;
      min-width: 1.8rem;
      font-family: monospace;
      flex-shrink: 0;
    }

    ol li a {
      color: #1a1a1a;
      text-decoration: none;
      font-size: 1rem;
    }

    ol li a:hover { color: #c8a96e; text-decoration: underline; }

    .badge {
      font-size: 0.68rem;
      background: #e8e6e0;
      color: #777;
      padding: 0.1rem 0.45rem;
      border-radius: 3px;
      margin-left: 0.25rem;
      vertical-align: middle;
      font-family: system-ui, sans-serif;
      white-space: nowrap;
    }

    .colab-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.68rem;
      background: #fff8e7;
      color: #e37400;
      border: 1px solid #f5c842;
      padding: 0.1rem 0.5rem;
      border-radius: 3px;
      text-decoration: none;
      margin-left: 0.25rem;
      vertical-align: middle;
      white-space: nowrap;
      font-family: system-ui, sans-serif;
    }
    .colab-link:hover { background: #fff3d0; }

    /* ── Footer ── */
    footer {
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid #e8e6e0;
      font-size: 0.82rem;
      color: #aaa;
      font-family: system-ui, sans-serif;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    footer a { color: #aaa; text-decoration: none; }
    footer a:hover { color: #c8a96e; }

    @media (max-width: 520px) {
      h1 { font-size: 1.8rem; }
      .track-desc { padding-left: 0; }
    }
  </style>
{% include "blocks/ga.html" %}
</head>
<body>

  <header class="site-header">
    <div class="by-line">By <a href="{{ header.by_url }}">{{ header.by }}</a></div>
    <h1>{{ header.title }}</h1>
    <p class="tagline">{{ header.tagline }}</p>

    <p class="philosophy">
      {{ header.philosophy | trim }}
    </p>
    <a class="philosophy-link" href="{{ header.philosophy_link }}">Read more about the philosophy &rarr;</a>
  </header>

  <div class="preface">
    <strong>How to use this</strong>
    {{ preface | trim }}
  </div>

{% for track in tracks %}
  <!-- Track {{ track.number }} -->
  <div class="track">
    <div class="track-header">
      <span class="track-number">{{ track.number }}</span>
      <span class="track-title">{{ track.title }}</span>
    </div>
    <p class="track-desc">{{ track.description }}</p>
    <ol>
{% for ch in track.chapters %}
      <li>
        <a href="{{ ch.href }}">{{ ch.title }}</a>
        <span class="badge">{{ ch.badge }}</span>
{% if ch.colab_url %}
        <a class="colab-link" href="{{ ch.colab_url }}" target="_blank">&#9654; Colab</a>
{% endif %}
      </li>
{% endfor %}
    </ol>
  </div>

{% endfor %}
  <footer>
    <span>Source on <a href="{{ footer.github_url }}" target="_blank" rel="noopener">GitHub</a> &middot; &copy; 2026 <a href="{{ footer.copyright_url }}" target="_blank" rel="noopener">{{ footer.copyright_holder }}</a></span>
    <span><a href="{{ footer.author_url }}">girisandeep.com</a></span>
  </footer>

</body>
</html>
